{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "phonetic-atlas-overlay",
  "version": "0.1.0",
  "identifier": "dev.phonetic-atlas.overlay",
  "build": {
    "devUrl": "http://127.0.0.1:7842",
    "frontendDist": "http://127.0.0.1:7842"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "overlay",
        "title": "phonetic-atlas overlay",
        "url": "about:blank",
        "width": 1440,
        "height": 40,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "resizable": false,
        "fullscreen": false,
        "focus": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ]
  }
}
